# ──────────────────────────────────────────────
# FitPlate — переменные окружения
# Скопируйте этот файл в .env и заполните значения
# ──────────────────────────────────────────────

# PostgreSQL — строка подключения к базе данных
# Render: вставьте Internal Database URL из раздела PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секрет для подписи сессионных cookies (произвольная длинная строка)
SESSION_SECRET=replace-with-a-long-random-secret

# Уровень логирования (debug | info | warn | error)
LOG_LEVEL=info

# Окружение (development | production)
NODE_ENV=production

# ──────────────────────────────────────────────
# OpenAI Vision API (через Replit AI Integrations)
# На Render получите ключ на https://platform.openai.com и замените значения ниже.
# На Replit эти переменные выставляются автоматически через AI Integrations.
# ──────────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-replace-with-your-openai-api-key
